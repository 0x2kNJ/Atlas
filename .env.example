# Atlas Protocol — environment variables
#
# Copy this file to .env and fill in values for your environment.
# The .env file is gitignored; this template is the canonical reference.

# ─── RPC endpoints ────────────────────────────────────────────────────────────
# Required for fork tests (test/fork/). Not needed for local Anvil development.
MAINNET_RPC_URL=
BASE_RPC_URL=
ARBITRUM_RPC_URL=

# ─── Block explorer API keys ─────────────────────────────────────────────────
# Required only when deploying to public networks with --verify.
ETHERSCAN_API_KEY=
BASESCAN_API_KEY=
ARBISCAN_API_KEY=

# ─── Deployment ───────────────────────────────────────────────────────────────
# Optional: set to transfer ownership of all deployed contracts away from the
# deployer key. If unset, the deployer retains ownership.
# ATLAS_OWNER=0x...

# ─── UI overrides ─────────────────────────────────────────────────────────────
# Override deployed contract addresses when running against a non-default chain.
# Defaults match the deterministic Anvil addresses in ui/src/contracts/addresses.ts.
# VITE_ADDR_MOCK_USDC=0x...
# VITE_ADDR_SINGLETON_VAULT=0x...
# VITE_ADDR_CAPABILITY_KERNEL=0x...
# VITE_ADDR_ENVELOPE_REGISTRY=0x...
# VITE_ADDR_RECEIPT_ACCUMULATOR=0x...
# VITE_ADDR_CREDIT_VERIFIER=0x...
# VITE_ADDR_CLAWLOAN_REPAY_ADAPTER=0x...
# VITE_ADDR_DIRECT_TRANSFER_ADAPTER=0x...
